{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 31,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "warnings": {
        "dev": true,
        "deprecated": true
      },
      "cacheVariables": {
        "CMAKE_EXPERIMENTAL_CXX_IMPORT_STD": "451f2fe2-a8a2-47c3-bc32-94786d8fc91b",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_CXX_SCAN_FOR_MODULES": "ON",
        "CMAKE_CXX_MODULE_STD": "ON"
      }
    },
    {
      "name": "x64",
      "hidden": true,
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },
    {
      "name": "log",
      "hidden": true,
      "cacheVariables": {
        "TEWI_ENABLE_LOGGING": "ON"
      }
    },
    {
      "name": "trace",
      "hidden": true,
      "inherits": "log",
      "cacheVariables": {
        "TEWI_ENABLE_TRACE": "ON"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": ["base", "x64", "log"],
      "generator": "Visual Studio 18 2026",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "intelliSenseMode": "windows-msvc-x64"
        }
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "inherits": ["base", "x64", "log"],
      "generator": "Ninja Multi-Config",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "intelliSenseMode": "linux-gcc-x64"
        }
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows x64 Debug (VS 2026)",
      "inherits": ["windows-base", "trace"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDebugDLL"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows x64 Release (VS 2026)",
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL"
      }
    },
    {
      "name": "windows-relwithdebinfo",
      "displayName": "Windows x64 RelWithDebInfo (VS 2026)",
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux x64 Debug (Ninja)",
      "inherits": ["linux-base", "trace"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux x64 Release (Ninja)",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-relwithdebinfo",
      "displayName": "Linux x64 RelWithDebInfo (Ninja)",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug-build",
      "displayName": "Windows Debug Build",
      "configurePreset": "windows-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-release-build",
      "displayName": "Windows Release Build",
      "configurePreset": "windows-release",
      "configuration": "Release"
    },
    {
      "name": "windows-relwithdebinfo-build",
      "displayName": "Windows RelWithDebInfo Build",
      "configurePreset": "windows-relwithdebinfo",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "linux-debug-build",
      "displayName": "Linux Debug Build",
      "configurePreset": "linux-debug",
      "configuration": "Debug"
    },
    {
      "name": "linux-release-build",
      "displayName": "Linux Release Build",
      "configurePreset": "linux-release",
      "configuration": "Release"
    },
    {
      "name": "linux-relwithdebinfo-build",
      "displayName": "Linux RelWithDebInfo Build",
      "configurePreset": "linux-relwithdebinfo",
      "configuration": "RelWithDebInfo"
    }
  ],
  "testPresets": [
    {
      "name": "test-base",
      "hidden": true,
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    },
    {
      "name": "windows-debug-test",
      "displayName": "Windows Debug Tests",
      "configurePreset": "windows-debug",
      "inherits": "test-base",
      "configuration": "Debug"
    },
    {
      "name": "windows-release-test",
      "displayName": "Windows Release Tests",
      "configurePreset": "windows-release",
      "inherits": "test-base",
      "configuration": "Release"
    },
    {
      "name": "linux-debug-test",
      "displayName": "Linux Debug Tests",
      "configurePreset": "linux-debug",
      "inherits": "test-base",
      "configuration": "Debug"
    },
    {
      "name": "linux-release-test",
      "displayName": "Linux Release Tests",
      "configurePreset": "linux-release",
      "inherits": "test-base",
      "configuration": "Release"
    }
  ]
}
